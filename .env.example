# AgentPay — Root Environment Template
# Copy to .env and fill in values. Sub-packages each have their own .env.example.

# ── Solana ──────────────────────────────────────────────────────────────────
SOLANA_CLUSTER=testnet
SOLANA_RPC_URL=https://api.testnet.solana.com
SOLANA_COMMITMENT=confirmed

# ── Deployed Program IDs (fill in after `anchor deploy`) ────────────────────
AGENT_REGISTRY_PROGRAM_ID=
PAYMENT_ROUTER_PROGRAM_ID=
SPLIT_VAULT_PROGRAM_ID=

# ── Deployer / Payer Wallet ──────────────────────────────────────────────────
# Base58 secret key OR JSON array string (e.g. from `solana-keygen`).
DEPLOYER_SECRET_KEY=

# ── Backend API ─────────────────────────────────────────────────────────────
API_PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://agentpay:agentpay@localhost:5432/agentpay

# ── Redis (optional — backend degrades gracefully without it) ────────────────
REDIS_URL=redis://localhost:6379

# ── Frontend (Next.js public vars) ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_SOLANA_CLUSTER=testnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.testnet.solana.com
NEXT_PUBLIC_AGENT_REGISTRY_PROGRAM_ID=
NEXT_PUBLIC_PAYMENT_ROUTER_PROGRAM_ID=
NEXT_PUBLIC_SPLIT_VAULT_PROGRAM_ID=

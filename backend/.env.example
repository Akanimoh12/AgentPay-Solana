# AgentPay Backend Environment

# Server
API_PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://agentpay:agentpay@localhost:5432/agentpay

# Redis (optional — degrades gracefully)
REDIS_URL=redis://localhost:6379

# Solana
SOLANA_CLUSTER=testnet
SOLANA_RPC_URL=https://api.testnet.solana.com
SOLANA_COMMITMENT=confirmed

# Deployed program IDs (fill in after `anchor deploy`)
AGENT_REGISTRY_PROGRAM_ID=
PAYMENT_ROUTER_PROGRAM_ID=
SPLIT_VAULT_PROGRAM_ID=

# Server-side payer (base58 secret key OR JSON array string).
# Required only if the backend signs transactions. Read-only mode works without.
PAYER_SECRET_KEY=
